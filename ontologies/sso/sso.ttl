# TYPE simple_datum_reference_modifier = EXTENSIBLE ENUMERATION OF
#    (free_state,
#     basic,
#     translation,
#     least_material_requirement,
#     maximum_material_requirement,
#     point,
#     line,
#     plane,
#     orientation,
#     any_cross_section,
#     any_longitudinal_section,
#     contacting_feature,
#     distance_variable,
#     degree_of_freedom_constraint_x,
#     degree_of_freedom_constraint_y,
#     degree_of_freedom_constraint_z,
#     degree_of_freedom_constraint_u,
#     degree_of_freedom_constraint_v,
#     degree_of_freedom_constraint_w,
#     minor_diameter,
#     major_diameter,
#     pitch_diameter);
# END_TYPE;
sso:SimpleDatumReferenceModifier
	a owl:Class , ssmeta:EnumerationClass ;
	owl:oneOf ( 
		sso:SimpleDatumReferenceModifier_free_state
		sso:SimpleDatumReferenceModifier_basic
		sso:SimpleDatumReferenceModifier_translation
		sso:SimpleDatumReferenceModifier_least_material_requirement
		sso:SimpleDatumReferenceModifier_maximum_material_requirement
		sso:SimpleDatumReferenceModifier_point
		sso:SimpleDatumReferenceModifier_line
		sso:SimpleDatumReferenceModifier_plane
		sso:SimpleDatumReferenceModifier_orientation
		sso:SimpleDatumReferenceModifier_any_cross_section
		sso:SimpleDatumReferenceModifier_any_longitudinal_section
		sso:SimpleDatumReferenceModifier_contacting_feature
		sso:SimpleDatumReferenceModifier_distance_variable
		sso:SimpleDatumReferenceModifier_degree_of_freedom_constraint_x
		sso:SimpleDatumReferenceModifier_degree_of_freedom_constraint_y
		sso:SimpleDatumReferenceModifier_degree_of_freedom_constraint_z
		sso:SimpleDatumReferenceModifier_degree_of_freedom_constraint_u
		sso:SimpleDatumReferenceModifier_degree_of_freedom_constraint_v
		sso:SimpleDatumReferenceModifier_degree_of_freedom_constraint_w
		sso:SimpleDatumReferenceModifier_minor_diameter
		sso:SimpleDatumReferenceModifier_major_diameter
		sso:SimpleDatumReferenceModifier_pitch_diameter ) .
