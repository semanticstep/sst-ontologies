sso:representedGeometry
	ssmeta:stepDmMap "RepresentedGeometry" ;
	a owl:ObjectProperty ;
	rdfs:subPropertyOf rep:itemIdentifiedRepresentationUsage ;
	rdfs:domain  sso:ShapeElement .

