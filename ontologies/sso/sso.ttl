################# shape_tolerance_schema    --  ISO 10303-47 ############

# SCHEMA shape_aspect_definition_schema ------------------------------------------------------------------------

# TYPE datum_reference_modifier = EXTENSIBLE SELECT
#    (datum_reference_modifier_with_value,
#     simple_datum_reference_modifier);
# END_TYPE;
sso:DatumReferenceModifier
	ssmeta:stepImSelectMap "datum_reference_modifier" ;
	a owl:Class , ssmeta:SelectClass ;
	owl:unionOf ( sso:DatumReferenceModifierWithValue sso:SimpleDatumReferenceModifier ) .

# TYPE datum_reference_modifier_type = EXTENSIBLE ENUMERATION OF
#    (circular_or_cylindrical,
#     spherical,
#     distance,
#     projected);
# END_TYPE;
sso:DatumReferenceModifierType
	a owl:Class , ssmeta:EnumerationClass ;
	owl:oneOf ( 
		sso:DatumReferenceModifierType_circular_or_cylindrical
		sso:DatumReferenceModifierType_spherical
		sso:DatumReferenceModifierType_distance
		sso:DatumReferenceModifierType_projected ) .
sso:DatumReferenceModifierType_circular_or_cylindrical
	ssmeta:stepImEnumerationMap "datum_reference_modifier_type.circular_or_cylindrical" ;
	a sso:DatumReferenceModifierType .
sso:DatumReferenceModifierType_spherical
	ssmeta:stepImEnumerationMap "datum_reference_modifier_type.spherical" ;
	a sso:DatumReferenceModifierType .
sso:DatumReferenceModifierType_distance
	ssmeta:stepImEnumerationMap "datum_reference_modifier_type.distance" ;
	a sso:DatumReferenceModifierType .
sso:DatumReferenceModifierType_projected
