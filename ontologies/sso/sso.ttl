# 	Id : OPTIONAL IdentifierSelect;
# 	Name : OPTIONAL DescriptorSelect;
# 	ClassifiedAs : OPTIONAL SET[1:?] OF Classification;
# 	MarketSegmentType : OPTIONAL ClassSelect;
# 	SameAs : OPTIONAL SET[1:?] OF Proxy;
# END_ENTITY;

# SST specific; class whose members are of type sso:ProductClass and that belong together for one organization
sso:ProductFamily
	rdf:type owl:Class , ssmeta:MainClass , lci:ClassOfIndividual ;
	skos:prefLabel "ProductFamily" ;
	skos:definition "Class of related ProductClasses with their ProductConfigurations and SpecificationItemCategories with their SpecificationItems." .

# ENTITY ProductConcept
# 	SUPERTYPE OF (ProductClass);
# 	Id : IdentifierSelect;
# 	Name : OPTIONAL DescriptorSelect;
# 	Description : OPTIONAL DescriptorSelect;
# 	ClassifiedAs : OPTIONAL SET[1:?] OF Classification;
# 	SameAs : OPTIONAL SET[1:?] OF Proxy;
# 	TargetMarket : OPTIONAL Market;
# END_ENTITY;
# ENTITY ProductClass
# 	SUBTYPE OF(ProductConcept);
# 	VersionId : OPTIONAL IdentifierSelect;
# 	LevelType : OPTIONAL ClassSelect;
# END_ENTITY;
#
# Class whose members are of type sso:ProductConfiguration
sso:ProductClass
	ssmeta:stepDmMap "ProductClass" ;
	rdf:type owl:Class, ssmeta:MainClass ;
	rdfs:subClassOf sso:CataloguePart ;
	skos:prefLabel "ProductClass" ;
	skos:definition "Class of similar ProductConfigurations." .

# ENTITY ProductClassRelationship;
# 	Id : OPTIONAL IdentifierSelect;
# 	Description : OPTIONAL DescriptorSelect;
# 	ClassifiedAs : OPTIONAL SET[1:?] OF Classification;
# 	RelationType : ClassSelect; => derivation, hierarchy, substitution, version sequence
# 	Relating : ProductClass;
# 	Related : ProductClass;
# WHERE
# 	WR1: Relating :<>: Related;
# END_ENTITY;

# ENTITY ProductConfiguration;
# 	Id : IdentifierSelect;
# 	Name : OPTIONAL DescriptorSelect;
# 	Description : OPTIONAL DescriptorSelect;
# 	VersionId : OPTIONAL IdentifierSelect;
# 	ClassifiedAs : OPTIONAL SET[1:?] OF Classification;
# 	DefiningGeometry : OPTIONAL GeometricModel;
# 	DefiningSpecifications : OPTIONAL SET[1:?] OF Specification;
# 	MemberOf : ProductConcept;
# 	SameAs : OPTIONAL SET[1:?] OF Proxy;
# INVERSE
# 	CorrespondingPartVersion : SET[0:1] OF ProductDesignAssociation FOR AssociatedConfiguration;
# END_ENTITY;
sso:ProductConfiguration
	ssmeta:stepDmMap "ProductConfiguration" ;
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf sso:CataloguePart ;
	skos:prefLabel "ProductConfiguration" ;
	skos:definition "Member of a ProductClass that is a manufacturable object or expected as so." .
sso:definingSpecificationItem
	rdf:type owl:ObjectProperty ;
	rdfs:domain sso:ProductConfiguration ;
	rdfs:range sso:SpecificationItem;
	skos:prefLabel "definingSpecificationItem" ;
	skos:definition "Selection of a SpecificationItem that is part of the definition of a ProductConfiguration." .

# ENTITY Specification;
# 	Id : IdentifierSelect;
# 	Name : OPTIONAL DescriptorSelect;
# 	Description : OPTIONAL DescriptorSelect;
# 	VersionId : OPTIONAL IdentifierSelect;
# 	ClassifiedAs : OPTIONAL SET[1:?] OF Classification;
# 	Category : SpecificationCategory;
# 	Package : BOOLEAN;
# END_ENTITY;
sso:SpecificationItem
	ssmeta:stepDmMap "Specification" ;
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf sso:Aspect ;
	skos:prefLabel "SpecificationItem" ;
	skos:definition "Member of a SpecificationCategory that defines an optional or mandatory characteristics for the ProductConfiguration members of ProductClasses." .

# ENTITY SpecificationAssignment;
# 	Description : OPTIONAL DescriptorSelect;
# 	ClassifiedAs : OPTIONAL SET[1:?] OF Classification;
# 	AssociationType : ClassSelect; => 
#     availability: ... a potential characteristic of any product belonging to a high level ProductClass, related to option or standard
#     identification: a characteristic that enables to distinguish the ProductClass from other ProductClasses
#     non-replaceable standard: ... a characteristic of all products belonging to the ProductClass
#     option: ... a characteristic of a product if explicitly chosen
#     part usage: ... a characteristic for the usage ... of an AlternativeSolution, Occurrence, ProcessPlan,ProcessOperationOccurrence
#     replaceable standard: ... a default characteristic of the products belonging to the ProductClass as long as no other Specification of the same SpecificationCategory is chosen
# 	AssignedSpecification : Specification;
# 	AssignedTo : ProductClass;
# END_ENTITY;
sso:optionalSpecificationItemOfMembers
	rdf:type owl:ObjectProperty ;
	rdfs:domain sso:ProductClass ;
	rdfs:range sso:SpecificationItem ;
	skos:prefLabel "optionalSpecificationItemOfMembers" ;
	skos:definition "Optional SpecificationItem for the members of a ProductClass." .
sso:mandatorySpecificationItemOfMembers
	rdf:type owl:ObjectProperty ;
	rdfs:domain sso:ProductClass ;
	rdfs:range sso:SpecificationItem ;
	skos:prefLabel "mandatorySpecificationItemOfMembers" ;
	skos:definition "Mandatory SpecificationItem for the members of a ProductClass." .


# ENTITY SpecificationCategory;
# 	Id : IdentifierSelect;
# 	Description : DescriptorSelect;
# 	ClassifiedAs : OPTIONAL SET[1:?] OF Classification;
# 	ImplicitExclusiveCondition : BOOLEAN; # see 2 cases below
# END_ENTITY;
# if ImplicitExclusiveCondition = false
sso:SpecificationItemCategory
	ssmeta:stepDmMap "SpecificationCategory" ;
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf sso:Aspect ;
	skos:prefLabel "SpecificationItemCategory" ;
	skos:definition "Group of SpecificationItems defining optional or mandatory characteristics for the ProductConfiguration members of ProductClasses." .

# if ImplicitExclusiveCondition = true
sso:SpecificationItemCategoryExclusive
	rdfs:subClassOf sso:SpecificationItemCategory ;
	skos:prefLabel "SpecificationItemCategory" ;
	skos:definition "Exclusive group of SpecificationItems defining optional or mandatory characteristics for the ProductConfiguration members of ProductClasses." .

# ENTITY SpecificationCategoryAssignment;
# 	Description : OPTIONAL DescriptorSelect;
# 	ClassifiedAs : OPTIONAL SET[1:?] OF Classification;
# 	AssignedCategory : SpecificationCategory;
# 	AssignedTo : ProductClass;
# 	Mandatory : BOOLEAN; ::  a Specification of the SpecificationCategory has to be used
# END_ENTITY;
sso:membersHaveOptionalSpecificationItemCategory
	rdf:type owl:ObjectProperty ;
	rdfs:domain sso:ProductClass ;
	rdfs:range  sso:SpecificationItemCategory ;
	skos:prefLabel "membersHaveOptionalSpecificationItemCategory" ;
	skos:definition "SpecificationItemCategory who's items are optionally available for the members of the ProductClass." .
sso:membersHaveMandatorySpecificationItemCategory
	rdf:type owl:ObjectProperty ;
	rdfs:domain sso:ProductClass ;
	rdfs:range sso:SpecificationItemCategory ;
	skos:prefLabel "membersHaveMandatorySpecificationItemCategory" ;
	skos:definition "SpecificationItemCategory who's items are mandatory (one or several) for the members of the ProductClass." .
sso:membersHaveNotSpecificationItemCategory # for directive for ProductClass subtypes
	rdf:type owl:ObjectProperty ;
	rdfs:domain sso:ProductClass ;
	rdfs:range sso:SpecificationItemCategory ;
	skos:prefLabel "membersHaveNotSpecificationItemCategory" ;
	skos:definition "SpecificationItemCategory items are not available for members of this ProductClass or sub-classes." .
sso:specificationItemCategoryOrder
	rdf:type owl:ObjectProperty ;
	rdfs:domain sso:ProductClass ;
	rdfs:range sso:SpecificationItemCategoryList ;
	skos:definition "Order in which SpecificationItemCategorys are displayed for a ProductClass." .
sso:SpecificationItemCategoryList
 	a rdfs:Class ;
	rdfs:subClassOf rdf:List ;
	rdfs:label "list of SpecificationCategories" ;
	ssmeta:ofType sso:SpecificationItemCategory .

# ENTITY SpecificationCategoryHierarchy;
# 	Description : OPTIONAL DescriptorSelect;
# 	ClassifiedAs : OPTIONAL SET[1:?] OF Classification;
# 	SubCategory : SpecificationCategory;
# 	SuperCategory : SpecificationCategory;
# END_ENTITY;
# what is exactly meant in terms of set theory?
# - is the SubCategory an extension of the SuperCategory 
#    => SuperCategory owl:subClassOf SubCategory
# - is the subCategory a reduced set of the SuperCategory 
#    => SubCategory owl:subClassOf SuperCategory

