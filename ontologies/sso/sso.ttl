# Copyright Semantic STEP Technology GmbH, Germany & DCT Co., Ltd. Tianjin, China

# This file defines the SemanticSTEP Ontology (abbreviated "sso")
# It uses concept defined in ISO 15925 and ISO 103030 series of standard but is significant different

####   How to name this new thing? ###
# the initial prefix was "ss" or "sso" that stands for "Semantic Step Ontology"; do we really want to bound to step?
# the namespace "ect" is an abbreviation for EpiCorTec that stands for "Epistle Core Technology"; maybe the new trademark?
# note: the namespace "eco" is used for Evidence & Conclusion Ontology  https://www.ebi.ac.uk/ols/ontologies/eco


@prefix sso:   <http://ontology.semanticstep.net/sso#> .
@prefix lci:   <http://ontology.semanticstep.net/lci#> .
@prefix owl:   <http://www.w3.org/2002/07/owl#> .
@prefix rdf:   <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs:  <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:   <http://www.w3.org/2001/XMLSchema#> .
@prefix ssmeta:   <http://ontology.semanticstep.net/ssmeta#> .
@prefix rep:   <http://ontology.semanticstep.net/rep#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix qau:      <http://ontology.semanticstep.net/qau#> .

# Major difference to ISO/TS 15926-12
# - FunctionalPhysicalObject is not used. A function is a conceptual non-physical thing on a design-level that might be related to a physical thing

<http://ontology.semanticstep.net/sso>
        rdf:type     owl:Ontology ;
        owl:imports   <http://ontology.semanticstep.net/lci> ,
			<http://ontology.semanticstep.net/qau> ;
        owl:versionInfo "0.01" .

# => use lci:Organization instead
# sso:Organization
#        rdf:type owl:Class , ssmeta:MainClass ;
#        rdfs:subClassOf lci:ArrangedIndividual .

sso:id
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf lci:identificationByLiteral .

sso:versionId
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf lci:identificationByLiteral .

sso:viewId
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf lci:identificationByLiteral .

sso:idOwner
	rdf:type owl:ObjectProperty ;
	rdfs:range [ a	owl:Class ;
                owl:unionOf  ( lci:Organization lci:InformationObject )
                     ] .

sso:organizationDomainId
	rdf:type owl:DatatypeProperty, owl:FunctionalProperty ;
	rdfs:subPropertyOf sso:id ;
	rdfs:domain lci:Organization ;
	skos:prefLabel "Internet domain of an Organization" .

sso:cageId
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf sso:id ;
	rdfs:domain lci:Organization ;
	skos:prefLabel "Commercial and Government Entity Code" ;
	skos:altLabel "CAGE Code" .

sso:europeanVatId
	rdf:type owl:DatatypeProperty , owl:FunctionalProperty ;
	rdfs:subPropertyOf sso:id ;
	rdfs:domain lci:Organization ;
	skos:prefLabel "value-added tax identification number" ;
	skos:altLabel "VAT identification number" ;
	skos:altLabel "VAT-ID" ;
	skos:altLabel "VATIN" .

# see https://en.wikipedia.org/wiki/Data_Universal_Numbering_System
sso:dunsId
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf sso:id ;
	rdfs:domain lci:Organization ;
	skos:prefLabel "Data Universal Numbering System" ;
	skos:altLabel "DUNS" ;
	skos:hiddenLabel "D-U-N-S" .

# see https://www.nato.int/structur/ac/135/nmcrl/data/nsn/
# sso:nsnId
# 	rdf:type owl:DatatypeProperty ;
# 	rdfs:subPropertyOf sso:id ;
# 	rdfs:domain sso:GenericPart ;
# 	skos:prefLabel "National Stock Number" ;
# 	skos:altLabel "NATO Stock Number" ;
# 	skos:altLabel "NSN" .

# https://en.wikipedia.org/wiki/ISBN
sso:isbnId
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf sso:id ;
	rdfs:domain lci:InformationObject ; 
	skos:prefLabel "ISBN" ;
	skos:altLabel "International Standard Book Number " .

# https://en.wikipedia.org/wiki/ISSN
sso:issnId
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf sso:id ;
	rdfs:domain lci:InformationObject ; 
	skos:prefLabel "ISNN" ;
	skos:altLabel "International Standard Serial Number" .

# https://en.wikipedia.org/wiki/Global_Trade_Item_Number
sso:ginId
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf sso:id ;
	rdfs:domain sso:GenericPart ;
	skos:prefLabel "GTIN" ;
	skos:altLabel "Global Trade Item Number" .

# https://en.wikipedia.org/wiki/International_Standard_Music_Number
sso:ismnId
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf sso:id ;
	rdfs:domain lci:InformationObject ; 
	skos:prefLabel "ISMN" ;
	skos:altLabel "International Standard Music Number  " .

# https://en.wikipedia.org/wiki/International_Article_Number
sso:nsnId
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf sso:id ;
	rdfs:domain sso:GenericPart ;
	skos:prefLabel "EAN" ;
	skos:altLabel "International Article Number" .

# https://en.wikipedia.org/wiki/Universal_Product_Code
sso:upcId
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf sso:id ;
	rdfs:domain sso:GenericPart ;
	skos:prefLabel "UPC" ;
	skos:altLabel "Universal Product Code " .


# Address stuff
sso:addressByLiteral
	rdf:type lci:RepresentationSpace , owl:AnnotationProperty ;
	rdfs:subPropertyOf lci:representationByLiteral .

################### Properties ######################

# ENTITY PropertyDefinition
# 	SUPERTYPE OF (ONEOF(MaterialPropertyDefinition, WireColourBasedIdentificationCode));
# 	Id : OPTIONAL IdentifierSelect;
# 	Description : OPTIONAL DescriptorSelect;
# 	VersionId : OPTIONAL IdentifierSelect;
# 	ClassifiedAs : OPTIONAL SET[1:?] OF Classification;
# 	PropertyType : OPTIONAL ClassSelect;
# 	AllowedUnits : OPTIONAL SET[1:?] OF UnitSelect;
# 	DefinedIn : OPTIONAL ExternalClassSystem;
# 	Definition : OPTIONAL ProxyItemSelect;
# 	SameAs : OPTIONAL SET[1:?] OF Proxy;
# END_ENTITY;
# => covered by lci:ObjectPropertyDefinition and lci:DatatypePropertyDefinition

# ENTITY WireColourBasedIdentificationCode
# 	SUBTYPE OF(PropertyDefinition);
# END_ENTITY;
sso:WireColourBasedIdentificationCode
	ssmeta:stepDmMap "WireColourBasedIdentificationCode" ;
#	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:PropertyDefinition .

################### Classifications ######################
# Source: AM1111 "Classification with attributes"
# Note: Domain-Model is quite different 

# TYPE classification_item_extended = EXTENSIBLE GENERIC_ENTITY SELECT BASED_ON classification_item WITH (
# 	classified_element_select) ;
# END_TYPE;
# 
# TYPE classified_element_select = EXTENSIBLE GENERIC_ENTITY SELECT (
# 	Product, 
# 	Product_version,
# 	Product_view_definition) ;
# END_TYPE;
# 
# TYPE external_class_select = SELECT(Plib_class_reference, External_class);
# END_TYPE;
# 
# TYPE definable_objects = SELECT (
# 	Product, 
# 	Product_version, 
# 	Product_view_definition);
# END_TYPE;

# ENTITY Class
#   SUPERTYPE OF (ONEOF (Class_by_extension,
#                        Class_by_intension));
#   id : STRING;
#   name : STRING;
#   description : OPTIONAL STRING;
# END_ENTITY;
#
# Note: Entity Class is from AM 1070 "Class" and together with Class_by_extension Class_by_intension
#       not used for SST. See Class_with_attributes

# ENTITY Class_with_attributes
# SUBTYPE OF (Class);
#   version_id: OPTIONAL STRING;
#   used_classification_system: OPTIONAL Classification_system;
# INVERSE
#   characterization_attributes: SET[0:?] OF Classification_attribute FOR characterized_class;
# END_ENTITY;
#
# Mapping:
#  Subclass of lci:Individual, depending of type this might be a specific individual e.g. sso:GenericPart
#  attribute used_classification_system is covered by rdf:type of a ClassificationSystem
#  attributre used_classification_system is covered by rdf:type of a sso:ClassificationSystem

# ENTITY Class_hierarchy;
#   super_class: Class_with_attributes;
#   sub_class: Class_with_attributes;
# END_ENTITY;
#
# => covered by rdfs:subClassOf

# ENTITY Classification_association
# SUBTYPE OF (Classification_assignment);
#    SELF\Classification_assignment.assigned_class: Class_with_attributes;
#    definitional: LOGICAL;
# WHERE
# WR1: NOT(definitional = TRUE) OR
#        (SIZEOF(QUERY(it<* SELF\Classification_assignment.items | 
#                  NOT('CLASSIFICATION_WITH_ATTRIBUTES_ARM.DEFINABLE_OBJECTS' IN TYPEOF(it)) )) = 0);
# WR2: SIZEOF(QUERY(it<* SELF\Classification_assignment.items |
#      NOT('CLASSIFICATION_WITH_ATTRIBUTES_ARM.CLASSIFIED_ELEMENT_SELECT' IN TYPEOF(it)) )) =0;
# END_ENTITY;
#
# Mapping: 
#   rdf:type of suitable subtype of lci:Individual
#   attribute definitional is skipped, might use lci:isDefinedBy if really needed

 
# ENTITY Classification_attribute;
#    id: STRING;
#    name: OPTIONAL STRING;
#    description: OPTIONAL STRING;
#    allowed_values: OPTIONAL SET[1:?] OF Measure_item;
#    characterized_class: Class_with_attributes;
#    attribute_definition: Independent_property;
# END_ENTITY;
#
# TBD

# ENTITY Classification_system;
#   id: STRING;
#   description: OPTIONAL STRING;
# END_ENTITY;
# THIS SHOULD BE DEPRECATED AND REPLACED BY NEW sso:ClassSystem
sso:ClassificationSystem
	ssmeta:stepDmMap "ClassificationSystem" ;
	rdf:type owl:Class , ssmeta:MainClass , lci:ClassOfIndividual .
 
sso:ClassSystem
	rdf:type owl:Class , ssmeta:MainClass , lci:ClassOfClassOfIndividual . # change to ClassOfIndividual or any subtype of
 
# This one is skipped, no need
# ENTITY External_class_with_attributes
# SUBTYPE OF (Class_with_attributes);
#   source: external_class_select;
# END_ENTITY;


################### ProductTaxonomySchema ######################

# not on the DO-Model, want to keep it in SST?
sso:Product
	rdfs:label "Product" ;
	rdf:type owl:Class, ssmeta:AbstractClass ;
	rdfs:subClassOf lci:ArrangedIndividual .

# not on the DO-Model, want to keep it in SST?
sso:TypicalPhysicalProduct
	rdfs:label "TypicalPhysicalProduct" ;
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf sso:Product .

# AP242 Domain Model: ENTITY IndividualPart 
# Modular ARM AM1164: Product_as_Individual 
# AP214: Physical_instance
# MIM: product_category.name='physically realized product'}
sso:SpecificPhysicalProduct
	rdfs:label "ProductAsIndividual" ;
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:PhysicalObject , lci:SpecificIndividual , lci:MaterializedPhysicalObject .

sso:InformationProduct
	rdfs:label "InformationProduct" ;
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:ArrangedIndividual .

# ENTITY Occurrence
# 	ABSTRACT
# 	SUPERTYPE OF (ONEOF(DefinitionBasedOccurrence, SpecifiedOccurrence));
# 	Id : IdentifierSelect;
# 	Description : OPTIONAL DescriptorSelect;
# 	ClassifiedAs : OPTIONAL SET[1:?] OF Classification;
# 	DefiningGeometry : OPTIONAL GeometricModel;
# 	Definition : OccurrenceOrOccurrenceDefinitionSelect;
# 	SameAs : OPTIONAL SET[1:?] OF Proxy;
# END_ENTITY;
#
# ENTITY DefinitionBasedOccurrence
# 	ABSTRACT
# 	SUPERTYPE OF (ONEOF(QuantifiedOccurrence, SingleOccurrence))
# 	SUBTYPE OF(Occurrence);
# 	SELF\Occurrence.Definition : OccurrenceDefinitionSelect; => lci:isDefinedBy
# END_ENTITY;
# both entities are covered in one

# IEC81346-1, rule 7: prefix a) "=" (EQUALS SIGN) when relating to the function aspect of the object;
sso:FunctionOccurrence
	sso:id "=" ;
	skos:prefLabel "function occurrence" ;
	ssmeta:stepDmMap "Occurrence" ;
	rdf:type owl:Class, ssmeta:MainClass ;
	rdfs:subClassOf sso:BreakdownOccurrence .
# IEC81346-1, rule 7: prefix b) "-" (HYPHEN-MINUS) when relating to the product aspect of the object;
sso:ProductOccurrence
	sso:id "-" ;
	skos:prefLabel "product occurrence" ;
	ssmeta:stepDmMap "Occurrence" ;
	rdf:type owl:Class, ssmeta:MainClass ;
	rdfs:subClassOf sso:BreakdownOccurrence .
# IEC81346-1, rule 7: prefix c) "+" (PLUS SIGN) when relating to the location aspect of the object;
sso:LocationOccurrence
	sso:id "+" ;
	skos:prefLabel "location occurrence" ;
	ssmeta:stepDmMap "Occurrence" ;
	rdf:type owl:Class, ssmeta:MainClass ;
	rdfs:subClassOf sso:BreakdownOccurrence .
# IEC81346-1, rule 7: prefix d) "%"" (PER CENT SIGN) when relating to the type aspect of an object;
sso:TypeOccurrence
	sso:id "%" ;
	skos:prefLabel "type occurrence" ;
	ssmeta:stepDmMap "Occurrence" ;
	rdf:type owl:Class, ssmeta:MainClass ;
	rdfs:subClassOf sso:BreakdownOccurrence .
# IEC81346-50, rule 6.2.1: prefix "$"" (DOLLAR) when relating to the process aspect of the object;
sso:ActivityOccurrence
	sso:id "$" ;
	skos:prefLabel "type occurrence" ;
	ssmeta:stepDmMap "Occurrence" ;
	rdf:type owl:Class, ssmeta:MainClass ;
	rdfs:subClassOf sso:BreakdownOccurrence , lci:Activity .
# sso:BreakdownOccurrence covers also other (user defined) types that are not product, function, location or type oriented:
# IEC81346-1, rule 7: prefix a) "#" IEC81346-1, rule 7: prefix a) 
sso:OtherOccurrence
	sso:id "#" ;
	skos:prefLabel "other aspect occurrence" ;
	ssmeta:stepDmMap "Occurrence" ;
	rdf:type owl:Class, ssmeta:MainClass ;
	rdfs:subClassOf sso:BreakdownOccurrence .

sso:VariantOccurrenceType
	rdf:type lci:ClassOfIndividual ;
	rdfs:subClassOf ssmeta:OptionClass .
# no sso:VariantOccurrence1 as this is the default if no variant given
sso:VariantOccurrence2
	skos:prefLabel "variant occurrence 2" ;
	rdf:type owl:Class, sso:VariantOccurrenceType, ssmeta:OptionClass ;
	rdfs:subClassOf sso:BreakdownOccurrence .
sso:VariantOccurrence3
	skos:prefLabel "variant occurrence 3" ;
	rdf:type owl:Class, sso:VariantOccurrenceType, ssmeta:OptionClass ;
	rdfs:subClassOf sso:BreakdownOccurrence .




# ENTITY SingleOccurrence
# 	SUBTYPE OF(DefinitionBasedOccurrence);
# END_ENTITY;
sso:SingleOccurrence
	ssmeta:stepDmMap "SingleOccurrence" ;
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf sso:ProductOccurrence .

# ENTITY QuantifiedOccurrence
# 	SUPERTYPE OF (ONEOF(CableOccurrence, WireOccurrence))
# 	SUBTYPE OF(DefinitionBasedOccurrence);
# 	Criterion : OPTIONAL MultiLingualStringSelect; => sso:quantifiedOccurrenceCriterionAsString
# 	Quantity : OPTIONAL ValueWithUnit; => sso:occurrenceQuantity
# WHERE
# WR1: EXISTS(Quantity) OR EXISTS(Criterion);
# END_ENTITY;
sso:QuantifiedOccurrence
	ssmeta:stepDmMap "QuantifiedOccurrence" ;
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf sso:ProductOccurrence .

sso:occurrenceQuantity
	ssmeta:stepDmMap "QuantifiedOccurrence.Quantity" ;
	rdf:type lci:PhysicalProperty , owl:FunctionalProperty , owl:ObjectProperty ;
	rdfs:domain sso:QuantifiedOccurrence .

sso:quantifiedOccurrenceCriterionAsString
	ssmeta:stepDmMap "QuantifiedOccurrence.Criterion" ;
	rdf:type owl:DatatypeProperty ;
	rdfs:domain sso:QuantifiedOccurrence ;
	rdfs:range xsd:string .

# ENTITY WireOccurrence
# 	SUBTYPE OF(QuantifiedOccurrence);
# END_ENTITY;
sso:WireOccurrence
	ssmeta:stepDmMap "WireOccurrence" ;
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf sso:QuantifiedOccurrence .

# ENTITY CableOccurrence
# 	SUBTYPE OF(QuantifiedOccurrence);
# END_ENTITY;
sso:CableOccurrence
	ssmeta:stepDmMap "CableOccurrence" ;
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf sso:QuantifiedOccurrence .

# ENTITY SpecifiedOccurrence
# 	SUBTYPE OF(Occurrence);
# 	SELF\Occurrence.Definition : Occurrence;
# 	UpperUsage : Occurrence; => sso:hasHigherUsage
# END_ENTITY;
sso:SpecifiedOccurrence
	ssmeta:stepDmMap "SpecifiedOccurrence" ;
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf sso:ProductOccurrence .

sso:hasHigherUsage
	rdf:type owl:ObjectProperty ;
	rdfs:subPropertyOf lci:partOf ;
	rdfs:domain sso:SpecifiedOccurrence ; # sso:PartDefinition ;
	rdfs:range sso:ProductOccurrence . # sso:PartVersion .
sso:higherUsageOf
	rdf:type owl:ObjectProperty ;
	owl:inverseOf sso:hasHigherUsage .

# An AssemblyGroupOccurrence is a type of Occurrence that groups other SingleOccurrences, QuantifiedOccurrences or GroupOccurrence together.
# If an AssemblyGroupOccurrence is used in an AssemblyDefiniton by an AssemblyOccurrenceRelationship 
# then all members of the GroupOccurrence are related to the AssemblyDefinition as well.
# This entity is not part of AP242!
# The functionality of this entity is similar to AP210 Assembly_group_component, but different as components do not used NAUO
# 
# ENTITY AssemblyGroupOccurrence
# 	SUBTYPE OF(Occurrence);
# 	SELF\Occurrence.Definition : Occurrence;
# 	members : SET[0:?] OF AssemblyGroupOccurrenceMembers; => sso:hasAssembledGroupOccurrence
sso:AssemblyGroupOccurrence
#	ssmeta:stepDmMap "" ;
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf sso:ProductOccurrence .
sso:AssemblyGroupOccurrenceMember
	rdf:type owl:Class , ssmeta:SelectClass ;
	owl:unionOf  ( sso:SingleOccurrence sso:QuantifiedOccurrence sso:AssemblyGroupOccurrence ) .

sso:assembledGroupOccurrenceOf
	rdf:type owl:ObjectProperty ;
	rdfs:subPropertyOf lci:assembledPartOf ;
	rdfs:domain sso:AssemblyGroupOccurrenceMember ;
	rdfs:range sso:AssemblyGroupOccurrence .
sso:hasAssembledGroupOccurrence
	rdf:type owl:ObjectProperty ;
	owl:inverseOf sso:assembledGroupOccurrenceOf .

# ORIGINAL PROPOSAL from 2024-06-23; see https://sd.iso.org/jira-pilot/browse/TCSC410303-2318
# UPDATED PROPOSAL from 2025-11-13; see https://sd.iso.org/jira-pilot/browse/TCSC410303-2318
# ENTITY AssemblyGroup
# 	SUPERTYPE OF (MatingGroup);
# 	Id : OPTIONAL IdentifierSelect;
# 	Name : OPTIONAL DescriptorSelect;
# 	Description : OPTIONAL DescriptorSelect;
# 	ClassifiedAs : OPTIONAL SET[1:?] OF Classification;
# 	MainMember : OPTIONAL Occurrence; => first item in collection of sso:hasAssemblyGroupMembers
# 	Members : OPTIONAL AssemblyGroupMemberSelect; => sso:hasAssemblyGroupMembers
# 	UsedIn : AssemblyDefinition; => sso:AssemblyDesign
# END_ENTITY;
# 
# TYPE AssemblyGroupMemberSelect = SELECT(
# 	OccurrenceMemberList,
# 	OccurrenceMemberSet
# );
# END_TYPE;
#
# TYPE OccurrenceMemberList = LIST[1:?] OF Occurrence;
# END_TYPE;
# 
# TYPE OccurrenceMemberSet = SET[1:?] OF Occurrence;
# END_TYPE;

sso:AssemblyGroup
	ssmeta:stepDmMap "AssemblyGroup" ;
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:ArrangedIndividual .
sso:assemblyGroupOf
	rdf:type owl:ObjectProperty ;
	rdfs:subPropertyOf lci:assembledPartOf ;
	rdfs:domain sso:AssemblyGroup ;
	rdfs:range sso:AssemblyDesign .
sso:hasAssemblyGroup
	rdf:type owl:ObjectProperty ;
	owl:inverseOf sso:assemblyGroupOf .
sso:ProductOccurrenceList
 	a rdfs:Class ;
	rdfs:subClassOf rdf:List ;
	rdfs:label "list of Occurrences" ;
	ssmeta:ofType sso:ProductOccurrence .
sso:assemblyGroupMemberOf
	rdf:type owl:ObjectProperty ;
	rdfs:subPropertyOf lci:assembledPartOf ;
	rdfs:domain sso:ProductOccurrenceList ;
	rdfs:range sso:AssemblyGroup .
sso:hasAssemblyGroupMember
	rdf:type owl:ObjectProperty ;
	owl:inverseOf sso:assemblyGroupMemberOf .


# ENTITY MatingGroup
# 	SUBTYPE OF(AssemblyGroup);
# 	MatingConnections : SET[1:?] OF MatingConnection;
# END_ENTITY;
sso:MatingGroup
	ssmeta:stepDmMap "MatingGroup" ;
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf sso:AssemblyGroup .

# ENTITY MatingConnection;
# 	Id : IdentifierSelect;
# 	Name : OPTIONAL DescriptorSelect;
# 	Description : OPTIONAL DescriptorSelect;
# 	ClassifiedAs : OPTIONAL SET[1:?] OF Classification;
# 	MatingType : OPTIONAL MatingTypeSelect; => additional rdf:type of MatingType(s)
# 	MatingMaterials : OPTIONAL SET[1:?] OF Occurrence;
# END_ENTITY;
sso:MatingConnection
	ssmeta:stepDmMap "MatingConnection" ;
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:ArrangedIndividual .
sso:matingMaterialOf
	rdf:type owl:ObjectProperty ;
	rdfs:subPropertyOf lci:assembledPartOf ;
	rdfs:domain sso:ProductOccurrence ;
	rdfs:range sso:MatingConnection .
sso:hasMatingMaterial
	rdf:type owl:ObjectProperty ;
	owl:inverseOf sso:matingMaterialOf .

################### PartTaxonomySchema ######################
sso:ProduciblePart
	rdfs:label "ProduciblePart" ;
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf sso:TypicalPhysicalProduct .

sso:TemplatePart
	rdfs:label "TemplatePart" ;
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf sso:TypicalPhysicalProduct .
	
sso:InformationCarrier
	rdfs:label "InformationCarrier" ;
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf sso:DiscretePart .
	
sso:PackagedPart
	rdfs:label "PackagedPart" ;
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf sso:DiscretePart .

# different from AP214 ProductSpecification. This tells that this is not a Part, but can be implemented by a Part
sso:ProductSpecification
	rdfs:label "ProductSpecification" ;
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf sso:DiscretePart .


sso:ContinuousPart
	rdfs:label "ContinuousPart" ;
	rdf:type owl:Class , ssmeta:OptionClass ;
	rdfs:subClassOf sso:ProduciblePart .

sso:CataloguePart
	rdfs:label "CataloguePart" ;
	rdf:type owl:Class , ssmeta:OptionClass ;
	rdfs:subClassOf sso:ProduciblePart .

sso:DetailedPart
	rdfs:label "DetailedPart" ;
	rdf:type owl:Class , ssmeta:OptionClass ;
	rdfs:subClassOf sso:ProduciblePart .

sso:DiscretePart
	rdfs:label "DiscretePart" ;
	rdf:type owl:Class , ssmeta:OptionClass ;
	rdfs:subClassOf sso:ProduciblePart .
	

