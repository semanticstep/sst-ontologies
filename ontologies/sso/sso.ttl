sso:datumModifiedType
	ssmeta:stepDmMap "datum_reference_modifier_with_value.modifier_type" ;
	a owl:ObjectProperty ;
#	rdfs:subPropertyOf  ;
	rdfs:domain  sso:DatumReferenceModifierWithValue ;
	rdfs:range sso:DatumReferenceModifierType .

sso:DatumModifierValue
	ssmeta:stepDmMap "datum_reference_modifier_with_value.modifier_value" ;
