# ENTITY ProductDesignAssociation;
# 	Description : OPTIONAL DescriptorSelect;
# 	ClassifiedAs : OPTIONAL SET[1:?] OF Classification;
# 	AssociatedConfiguration : ProductConfiguration;
# 	AssociatedDesign : PartVersion;
# END_ENTITY;
sso:productDesignAssociation
	rdf:type owl:ObjectProperty ;
	rdfs:domain sso:ProductConfiguration ;
	rdfs:range  sso:GenericPart ;
	skos:prefLabel "productDesignAssociation" .
#	skos:definition "" .

sso:productConfigurationAssociation
	rdf:type owl:ObjectProperty ;
	rdfs:domain sso:ProductConfiguration ;
	owl:inverseOf sso:productDesignAssociation .

