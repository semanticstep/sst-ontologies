	ssmeta:stepDmMap "HarnessNode" ;
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf sso:PartShapeElement .

sso:attachedFeature
	rdf:type owl:ObjectProperty ;
	rdfs:subPropertyOf lci:directlyConnectedTo ;
	rdfs:domain sso:HarnessNode ;
	rdfs:range sso:OccurrenceShapeFeature .

sso:attachedOccurrence
	rdf:type owl:ObjectProperty ;
	rdfs:subPropertyOf lci:directlyConnectedTo ;
	rdfs:domain sso:HarnessNode ;
	rdfs:range sso:ProductOccurrence .

sso:HarnessNode_VertexPoint
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf sso:HarnessNode , rep:VertexPoint , rep:Point .

sso:HarnessNode_VertexPointOnCurve
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf sso:HarnessNode , rep:VertexPoint , rep:PointOnCurve .

