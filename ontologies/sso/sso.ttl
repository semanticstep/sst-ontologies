# DERIVE
# 	FiberDirection : PlyAngleRepresentation := SELF\RepresentationRelationship.Relating;
# 	ReinforcementDirection : ReinforcementOrientationBasis := SELF\RepresentationRelationship.Related;
# END_ENTITY;
# => TBD

# ENTITY LaidOrientationAngle
# 	SUBTYPE OF(PlyOrientationAngle);
# END_ENTITY;
# => TBD

# ENTITY DrapedOrientationAngle
# 	SUBTYPE OF(PlyOrientationAngle);
# END_ENTITY;
# => TBD

# ENTITY GeometricRepresentationRelationship
# 	ABSTRACT
# 	SUPERTYPE OF (ONEOF(GeneralGeometricRepresentationRelationship, GeometricRepresentationRelationshipWithCartesianTransformation, GeometricRepresentationRelationshipWithPlacementTransformation, GeometricRepresentationRelationshipWithSameCoordinateSpace))
# 	SUBTYPE OF(RepresentationRelationship);
# 	SELF\RepresentationRelationship.Relating : GeometricRepresentationSelect;
# 	SELF\RepresentationRelationship.Related : GeometricRepresentationSelect;
# END_ENTITY;

# ENTITY GeneralGeometricRepresentationRelationship
# 	SUBTYPE OF(GeometricRepresentationRelationship);
# 	RelationType : ClassSelect;
# END_ENTITY;
# => rep:shapeRepresentationRelationshipWithTransformation

# ENTITY GeometricRepresentationRelationshipWithCartesianTransformation
# 	SUBTYPE OF(GeometricRepresentationRelationship);
# 	Transformation : CartesianTransformation;
# WHERE
# WR1: SELF\GeometricRepresentationRelationship.Relating.ContextOfItems :<>: SELF\GeometricRepresentationRelationship.Related.ContextOfItems;
# END_ENTITY;
# => rep:shapeRepresentationRelationshipWithCartesianTransformation

# ENTITY GeometricRepresentationRelationshipWithPlacementTransformation
# 	SUBTYPE OF(GeometricRepresentationRelationship);
# 	Origin : AxisPlacement;
# 	Target : AxisPlacement;
# WHERE
# WR1: SELF\GeometricRepresentationRelationship.Relating.ContextOfItems :<>: SELF\GeometricRepresentationRelationship.Related.ContextOfItems;
# END_ENTITY;
# => rep:shapeRepresentationRelationshipWithPlacementTransformation

# ENTITY GeometricRepresentationRelationshipWithSameCoordinateSpace
# 	SUBTYPE OF(GeometricRepresentationRelationship);
# DERIVE
# 	SELF\RepresentationRelationship.Definitional : BOOLEAN := TRUE;
# WHERE
# WR1: SELF\RepresentationRelationship.Relating.ContextOfItems :=: SELF\RepresentationRelationship.Related.ContextOfItems;
# END_ENTITY;
# => rep::shapeRepresentationRelationshipWithSameGeometricRepresentationContext

