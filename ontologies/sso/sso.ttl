#### Breakdown #####
# not taken from AP242-DOM or AP242-ARM/MIN, nor S300L
# instead adoption from IEC 81346-1 functionality using some basic AP242 concepts
sso:BreakdownSystem
	rdfs:label "BreakdownSystem" ;
	rdf:type lci:ClassOfIndividual , ssmeta:MainClass ;
	rdfs:subClassOf lci:Individual ;
	skos:definition "entity to group several sso:Breakdown objects together that define different aspects of the same thing." ;
#	skos:example "" ;
.
# represent the Object from IEC 81346 part 1; only needed for top nodes (?) and if there are more than 1 views/occurrence
# A BreakdownObject is an implicit part of a BreakdownSystem because it requires at least one BreakdownOccurrence
# that is either a direct (if top) or indirect part (elsewhetre in the tree) of a BreakdownSystem.
sso:BreakdownObject
	rdfs:label "BreakdownObject" ;
	rdf:type lci:ClassOfIndividual , ssmeta:MainClass ;
	rdfs:subClassOf lci:Individual ;
	skos:definition "entity involved in a process of development, implementation, usage, and disposal." ;
	skos:note "...." ;
.

# represents IEC 81436-1 ObjectOccurrence
# A BreakdownOccurrence is a part of either a bigger BreakdownOccurrence or of a BreakdownSystem if it is the top node of a tree.
# Because of this a BreakdownOccurrence is either a direct or an indirect part of a BreakdownSystem.
# Consequently a BreakdownOccurrence is a member of exactly one tree of BreakdownOccurrences.
# In addition a BreakdownOccurrence is a part of a BreakdownObject if one is defined for it. 
# This makes the BreakdownObjects also indirect part of a BreakdownSystem (as a kind of deduction).
# see subtypes:
# => sso:FunctionalOccurrence
# => sso:ProductOccurrence
# => sso:LocationOccurrence
# => sso:TypeOccurrence
sso:BreakdownOccurrence
	rdfs:label "BreakdownOccurrence" ;
	rdf:type lci:ClassOfIndividual , ssmeta:MainClass ;
	rdfs:subClassOf lci:Individual ;
	skos:definition "a ..." ;
.	

# :breakdown1 sso:breakdownOf :systemX .
# :systemX sso:hasBreakdown :breakdown1 .
sso:breakdownOf
	rdf:type owl:ObjectProperty , owl:TransitiveProperty ;
	rdfs:subPropertyOf lci:arrangedPartOf ;
	rdfs:domain sso:BreakdownOccurrence ;
	rdfs:range sso:BreakdownSystem ;
	skos:definition "Top BreakdownOccurrence to BreakdownSystem relationship" ;
	skos:prefLabel "breakdownOf" ;
.
sso:hasBreakdown
	rdf:type owl:ObjectProperty ;
	owl:inverseOf sso:breakdownOf ;
	skos:definition "BreakdownSystem to top BreakdownOccurrence relationship" ;
	skos:prefLabel "sso:hasBreakdown" ;
.

# :smallerView sso:breakdownElementOf :biggerView .
# :biggerView sso:hasBreakdownElement :smallerView .
sso:breakdownOccurrenceOf
	rdf:type owl:ObjectProperty , owl:TransitiveProperty ;
	rdfs:subPropertyOf lci:arrangedPartOf ;
	rdfs:domain sso:BreakdownOccurrence ;
	rdfs:range sso:BreakdownOccurrence ;
	skos:definition "smaller BreakdownOccurrence to bigger BreakdownOccurrence relationship" ;
	skos:prefLabel "breakdownOccurrenceOf" ;
.
sso:hasBreakdownOccurrence
	rdf:type owl:ObjectProperty ;
	owl:inverseOf sso:breakdownOccurrenceOf ;
	skos:definition "bigger BreakdownOccurrence to smaller BreakdownOccurrence relationship" ;
	skos:prefLabel "hasBreakdownElement" ;
.

# :functionalViewA sso:BreakdownOccurrenceOf :objectX .
# :objectX sso:hasBreakdownOccurrence :functionalViewA .
sso:breakdownOccurrenceViewOf
	rdf:type owl:ObjectProperty , owl:TransitiveProperty ;
	rdfs:subPropertyOf lci:arrangedPartOf ;
	rdfs:domain sso:BreakdownOccurrence ;
	rdfs:range sso:BreakdownObject ;
	skos:definition "BreakdownOccurrence to BreakdownObject relationship of which it is a view" ;
	skos:prefLabel "BreakdownOccurrenceOf" ;
.
sso:hasBreakdownOccurrenceView
	rdf:type owl:ObjectProperty ;
	owl:inverseOf sso:breakdownOccurrenceViewOf ;
	skos:definition "BreakdownObject to BreakdownOccurrence relationship that is a view of" ;
	skos:prefLabel "breakdownOccurrenceViewOf" ;
.
#####

sso:refDes
	skos:prefLabel "reference designator" ;
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf sso:id ;
.
sso:refDes1
	skos:prefLabel "single level reference designator" ;
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf sso:refDes ;
.
sso:refDesN
	skos:prefLabel "multi level reference designator" ;
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf sso:refDes ;
.
sso:refDesClass
	skos:prefLabel "class based single level reference designator" ;
	rdf:type owl:DatatypeProperty , ssmeta:AbstractProperty ;
	rdfs:subPropertyOf sso:refDes1 ;
.
# this abstract property is indicating that the strict rules about breakdown types according to IEC 81346-1 applies
sso:refDes81346
	skos:prefLabel "class based single level reference designator" ;
	rdf:type owl:DatatypeProperty , ssmeta:AbstractProperty ;
	rdfs:subPropertyOf sso:refDesClass ;
.
sso:refDes81346_2_inherent_function
	skos:prefLabel "class based single level reference designator as defined by ISO/IEC 81346-2:2009, Table 1 to 3" ;
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf sso:refDes81346 ;
.
sso:refDes81346_2_space
	skos:prefLabel "class of space; ISO/IEC 81346-2:2019, Table 4" ;
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf sso:refDes81346 ;
.
sso:refDes81346_2_infrastructure
	skos:prefLabel "class of infrastructure object; ISO/IEC 81346-2:2019, Table 5" ;
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf sso:refDes81346 ;
.
sso:refDes81346_14_prime_system
	skos:prefLabel "class of prime systems for manufacturing; ISO/IEC 81346-14:2024, Table AA.1" ;
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf sso:refDes81346 ;
.
sso:refDes81346_14_technical_system
	skos:prefLabel "class of technical systems for manufacturing; ISO/IEC 81346-14:2024, Table AA.2" ;
	rdf:type owl:DatatypeProperty ;
	rdfs:subPropertyOf sso:refDes81346 ;
.





###################   ######################

sso:GenericPart
	rdfs:label "GenericPart" ;
	rdf:type owl:Class , ssmeta:AbstractClass ;
	rdfs:subClassOf
		lci:TypicalIndividual , 
		lci:MaterializedPhysicalObject;
    owl:disjointUnionOf (sso:Part sso:PartSpecification) ;
	skos:definition "non-actual materialized physical product offered to the market" .
	

# ENTITY Part;
# 	Id : IdentifierSelect;  => in most cases just sso:id or subype
# 	Name : DescriptorSelect; => in most cases just rdfs:label
# 	Description : OPTIONAL DescriptorSelect; => in most cases just rdfs:comment
# 	ClassifiedAs : OPTIONAL SET[1:?] OF Classification; => skip
# 	PartTypes : SET[1:?] OF PartClassSelect;  => ...
# 	SameAs : OPTIONAL SET[1:?] OF Proxy;  => skip
# 	Versions : SET[1:?] OF PartVersion; => sso:hasPartVersion 
# END_ENTITY;
sso:Part
	ssmeta:stepDmMap "Part" ;
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf sso:GenericPart ;
	skos:definition "generic part offered or produced by a particular organization that is identified by part number of that organization" .
	
sso:ConfigurablePart
	rdfs:label "ConfigurablePart" ;
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf sso:GenericPart ;
	skos:definition "generic part for which several variants are available by configuration" .
	
sso:NonConfigurablePart
	rdfs:label "NonConfigurablePart" ;
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf sso:GenericPart ;
	skos:definition "generic part that is not configurable" .
	
sso:PartSpecification
	rdfs:label "PartSpecification" ;
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf sso:NonConfigurablePart ;
	skos:definition "a non configurable part that is the result of the configuring of a configurable part" .
	
sso:partVersionOf 
	rdf:type owl:ObjectProperty ;
	rdfs:subPropertyOf lci:arrangedPartOf ;
	rdfs:domain sso:PartVersion ;
	rdfs:range sso:Part .
sso:hasPartVersion 
	ssmeta:stepDmMap "Versions" ;
	rdf:type owl:ObjectProperty ;
	owl:inverseOf sso:partVersionOf .

# ENTITY PartVersion;
# 	Id : IdentifierSelect;  => sso:versionId if not empty string
# 	Description : OPTIONAL DescriptorSelect; => rdfs:comment if not empty string
# 	ClassifiedAs : OPTIONAL SET[1:?] OF Classification;
# 	SameAs : OPTIONAL SET[1:?] OF Proxy;
# 	Views : OPTIONAL SET[1:?] OF PartView;  => sso:hasProductDefinition
# INVERSE
# 	CorrespondingProductConfigurations : SET[0:?] OF ProductDesignAssociation FOR AssociatedDesign;
# 	VersionOf : Part FOR Versions; => partDefinitionOf
# END_ENTITY;
sso:PartVersion
	ssmeta:stepDmMap "PartVersion" ;
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf lci:ArrangedIndividual .	

sso:partDefinitionOf
	rdf:type owl:ObjectProperty ;
	rdfs:subPropertyOf lci:partOf ;
	rdfs:domain sso:PartDefinition ;
	rdfs:range sso:PartVersion .
sso:hasProductDefinition
	ssmeta:stepDmMap "Views" ;
	rdf:type owl:ObjectProperty ;
	owl:inverseOf sso:partDefinitionOf .

# ?? makes sense ??
# this supertype is not an ArrangedIndividual, so it has no features or any known identifyable parts
sso:PartDefinition
        rdf:type owl:Class , ssmeta:MainClass ;
        rdfs:subClassOf lci:Individual .

sso:netWeight
	skos:prefLabel "net weight" ;
	skos:definition "mass of the weighed object without packing and transport equipment" ;
