#   SUBTYPE OF (Composite_shape_element);
# END_ENTITY;
sso:ContinuousShapeElement
	ssmeta:stepImEntityMap "all_around_shape_aspect" ;
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf sso:CompositeShapeElement .

# ENTITY all_around_shape_aspect
#   SUBTYPE OF (continuous_shape_aspect);
# END_ENTITY;
sso:AllAroundShapeElement
	ssmeta:stepImEntityMap "all_around_shape_aspect" ;
	rdf:type owl:Class , ssmeta:MainClass ;
	rdfs:subClassOf sso:ContinuousShapeElement .

# ENTITY apex
#   SUBTYPE OF (derived_shape_aspect);
