	rdf:type owl:ObjectProperty ;
	rdfs:subPropertyOf lci:hasAssembledPart ;
	rdfs:range sso:AssemblyDesign .
sso:promissoryAssemblyOccurrenceUsage 
	rdf:type owl:ObjectProperty ;
	owl:inverseOf sso:occurrencePromissoryAssemblyUsage .
